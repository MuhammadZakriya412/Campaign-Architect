rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users metadata
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Brand Profiles
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Campaign Histories
    match /campaign_histories/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Generated Images
    match /user_images/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
